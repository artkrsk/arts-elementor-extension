{
  "name": "@arts/elementor-extension",
  "author": "Artem Semkin",
  "version": "1.0.7",
  "type": "module",
  "license": "MIT",
  "description": "Library for creating Elementor extensions, widgets, skins, tabs, and more in declarative way",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=23.0.0"
  },
  "dependencies": {
    "@arts/utilities": "file:../ArtsUtilities"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "4.1.5",
    "archiver": "^7.0.1",
    "browser-sync": "^3.0.4",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cypress": "^15.14.1",
    "debounce": "^3.0.0",
    "depcheck": "^1.4.7",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "npm-check-updates": "^22.0.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wp-pot": "^1.10.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=2.0.0 <3.0.0": "2.1.0",
      "flatted": "3.4.2",
      "js-yaml": ">=4.1.1",
      "lodash": ">=4.18.0",
      "minimatch@>=3.0.0 <4.0.0": "3.1.5",
      "minimatch@>=7.0.0 <8.0.0": "7.4.9",
      "minimatch@>=9.0.0 <10.0.0": "9.0.9",
      "picomatch@>=2.0.0 <3.0.0": "2.3.2",
      "picomatch@>=4.0.0 <5.0.0": "4.0.4",
      "postcss": ">=8.5.10",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "serialize-javascript": "7.0.5",
      "swiper": ">=12.1.2",
      "systeminformation": ">=5.31.0",
      "undici": "^7.24.0",
      "uuid": ">=14.0.0",
      "vite": ">=8.0.0",
      "yaml@>=1.0.0 <2.0.0": "1.10.3"
    }
  },
  "scripts": {
    "dev": "node __build__/src/index.js dev",
    "build": "node __build__/src/index.js build",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u && pnpm install",
    "format": "prettier --write 'src/js/**/*.{js,jsx,json,css,ts,tsx}'",
    "format:check": "prettier --check 'src/js/**/*.{js,jsx,json,css,ts,tsx}'",
    "lint": "eslint 'src/js/**/*.{js,ts,jsx,tsx}'",
    "lint:fix": "eslint --fix 'src/js/**/*.{js,ts,jsx,tsx}'"
  }
}
